[Unit]
Description=Mlai-Lab Frontend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Mlai-lab/frontend
ExecStart=/usr/bin/node /root/Mlai-lab/frontend/node_modules/.bin/vite
Restart=always
RestartSec=5
StandardOutput=null
StandardError=null

[Install]
WantedBy=multi-user.target