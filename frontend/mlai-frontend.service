[Unit]
Description=Mlai-Lab Frontend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Mlai-lab/frontend
Environment="PATH=/usr/local/bin:/usr/bin:/bin"
ExecStart=/root/Mlai-lab/frontend/node_modules/.bin/vite --host 0.0.0.0 --port 3000
ExecReload=/bin/kill -s HUP $MAINPID
KillMode=mixed
TimeoutStopSec=5
PrivateTmp=true
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
